// Prisma schema for vath
// Local dev: sqlite (file:./dev.db)
// Production (Vercel/Neon): change provider to "postgresql" and run `prisma db push`
generator client {
  provider      = "prisma-client-js"
  // Vercel lambdas run on Amazon Linux 2023 (openssl 3.0). Without this the
  // generated engine binary won't load in production.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  publisher   String
  description String?
  imageUrl    String
  bannerUrl   String?
  currencyName String   // e.g. "Diamonds", "UC", "Genesis Crystals"
  uidLabel    String   @default("Player ID")
  uidExample  String?  // e.g. "12345678 (1234)"
  requiresServer Boolean @default(false)
  // JSON-encoded string array (SQLite has no native array type)
  servers     String    @default("[]")
  featured    Boolean   @default(false)
  active      Boolean   @default(true)
  sortOrder   Int       @default(0)
  seoTitle       String?
  seoDescription String?
  products    Product[]
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  name        String   // e.g. "86 Diamonds"
  amount      Int      // 86
  bonus       Int      @default(0) // bonus diamonds
  priceUsd    Float    // price in USD
  priceKhr    Float?   // price in Cambodian Riel (optional auto-calc)
  badge       String?  // "Best Value", "Hot", "New"
  imageUrl    String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gameId, active])
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique // human-friendly: RT-XXXXXX
  gameId         String
  game           Game         @relation(fields: [gameId], references: [id])
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  playerUid      String
  serverId       String?
  playerNickname String?      // optional nickname pulled after validation
  customerEmail  String?
  customerPhone  String?
  amountUsd      Float
  amountKhr      Float?
  currency       String       @default("USD")
  paymentMethod  String       // ABA_PAY | BINANCE_PAY | MANUAL
  paymentRef     String?      // gateway transaction id
  paymentUrl     String?      // redirect URL from gateway
  qrString       String?      // KHQR EMV payload (for on-site display)
  paymentExpiresAt DateTime?  // QR/payment expiry time
  status         String       @default("PENDING") // PENDING | PAID | PROCESSING | DELIVERED | FAILED | REFUNDED | CANCELLED
  deliveryNote   String?      // admin notes about delivery
  failureReason  String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  paidAt         DateTime?
  deliveredAt    DateTime?
  promoCodeId    String?
  promoCode      PromoCode? @relation(fields: [promoCodeId], references: [id])
  discountUsd    Float      @default(0)

  @@index([status])
  @@index([createdAt])
  @@index([customerEmail])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    // PERCENT | FIXED
  discountValue Float     // e.g. 10 for 10% or 0.50 for $0.50
  minOrderUsd   Float     @default(0)
  maxUses       Int       @default(0) // 0 = unlimited
  usedCount     Int       @default(0)
  expiresAt     DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String    @default("ADMIN") // ADMIN | SUPERADMIN
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?
}

model Settings {
  id          Int      @id @default(1)
  siteName    String   @default("vath")
  exchangeRate Float   @default(4100) // KHR per 1 USD
  supportTelegram String? @default("@VaTHana_Sem")
  supportEmail String? @default("thiefxgt@gmail.com")
  maintenanceMode Boolean @default(false)
  maintenanceMessage String?
  announcement String?
  announcementTone String? @default("info") // info | warning | promo
  telegramBotToken String?
  telegramChatId   String?
  updatedAt   DateTime @updatedAt
}

model HeroBanner {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  ctaLabel  String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String    // plain text / lightweight HTML
  coverUrl    String?
  tag         String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String?
  action     String   // e.g. order.mark_paid, banner.create, game.update
  targetType String?  // order | game | banner | faq | blog | banlist | settings
  targetId   String?
  details    String?  // JSON-encoded metadata
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType, targetId])
}

model BlockedIdentity {
  id        String   @id @default(cuid())
  type      String   // email | phone | ip | uid
  value     String
  reason    String?
  createdAt DateTime @default(now())

  @@unique([type, value])
}
